    "windsurf",
    "copilot",
    "kiro",
    "trae",
    "roocode",
    "codex",
    "qoder",
    "ai",
    "skill"
  ],
  "author": "kunkun-c",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kunkun-c/frontend-system-architect.git"
  },
  "bugs": {
    "url": "https://github.com/kunkun-c/frontend-system-architect/issues"
  },
  "homepage": "https://github.com/kunkun-c/frontend-system-architect#readme",
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
