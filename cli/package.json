{
  "name": "fe-architect-cli",
  "version": "2.1.1",
  "description": "CLI to install Frontend System Architect skill for AI coding assistants",
  "type": "module",
  "bin": {
    "fea": "./dist/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build",
    "test": "node dist/index.js --help"
  },
